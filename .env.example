# Admin password for the portfolio admin panel
# Change this to a secure password
ADMIN_PASSWORD=joseigna3002@

# Server port (default: 3000)
PORT=3000

# Gemini API key (if used)
GEMINI_API_KEY=

# Supabase (required for data persistence)
